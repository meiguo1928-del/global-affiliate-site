---
import { getCollection } from 'astro:content';
import type { Locale } from '../config';
import { ui } from '../i18n/ui';
import { localePath } from '../utils/locale';

interface Props {
  lang: Locale;
  permalink: string;
  keywords?: string[];
}

const { lang, permalink, keywords = [] } = Astro.props;
const label = ui[lang].home.readMore;

const topicRules: { label: string; patterns: RegExp }[] = [
  { label: 'hosting', patterns: /hosting|hostinger|bluehost|website.?builder/i },
  { label: 'security', patterns: /vpn|nordvpn|surfshark|security/i },
  { label: 'ai-tools', patterns: /ai|jasper|copy\.?ai|writing|canva|semrush|email|marketing/i },
];

const currentTopic =
  topicRules.find((rule) => rule.patterns.test(keywords.join(' ')))?.label ?? 'ai-tools';

const articles = (await getCollection('articles'))
  .filter((a) => a.data.lang === lang && a.data.permalink !== permalink)
  .map((a) => {
    const text = [...(a.data.keywords ?? []), a.data.title, a.data.description].join(' ');
    const topic =
      topicRules.find((rule) => rule.patterns.test(text))?.label ?? 'ai-tools';
    const topicMatch = topic === currentTopic ? 2 : 0;
    const keywordHits = keywords.filter((k) => text.toLowerCase().includes(k.toLowerCase())).length;
    return { entry: a, score: topicMatch + keywordHits };
  })
  .sort((a, b) => b.score - a.score || b.entry.data.date.valueOf() - a.entry.data.date.valueOf());

const picked = (articles.some((item) => item.score > 0)
  ? articles.filter((item) => item.score > 0)
  : articles.filter((item) => {
      const text = [...(item.entry.data.keywords ?? []), item.entry.data.title].join(' ');
      const topic =
        topicRules.find((rule) => rule.patterns.test(text))?.label ?? 'ai-tools';
      return topic === currentTopic;
    })
)
  .slice(0, 3)
  .map((item) => item.entry);

if (picked.length === 0) return null;
---

<section class="related-guides">
  <h2>{lang === 'en' ? 'Related guides' : ui[lang].home.latest}</h2>
  <div class="related-grid">
    {
      picked.map((article) => (
        <a class="related-card" href={localePath(lang, article.data.permalink)}>
          <h3>{article.data.title}</h3>
          <p>{article.data.description}</p>
          <span>{label}</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .related-guides {
    margin: 2.5rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid #dbe3ef;
  }
  .related-guides h2 {
    margin: 0 0 1rem;
    font-size: 1.2rem;
  }
  .related-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .related-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 16px;
    padding: 1rem 1.05rem;
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
  }
  .related-card:hover {
    transform: translateY(-2px);
    border-color: #93c5fd;
    box-shadow: 0 16px 38px rgba(37, 99, 235, 0.1);
  }
  .related-card h3 {
    margin: 0 0 0.45rem;
    font-size: 0.98rem;
    color: #0f172a;
  }
  .related-card p {
    margin: 0;
    font-size: 0.86rem;
    color: #475569;
    line-height: 1.5;
  }
  .related-card span {
    display: inline-block;
    margin-top: 0.75rem;
    color: #2563eb;
    font-size: 0.84rem;
    font-weight: 800;
  }
</style>
