---
import { SITE, LOCALES, LOCALE_LABELS, type Locale } from '../config';
import { ui } from '../i18n/ui';
import { localePath } from '../utils/locale';

interface Props {
  lang: Locale;
  subPath?: string;
}

const { lang, subPath = '' } = Astro.props;
const t = ui[lang].nav;
const homeHref = localePath(lang);
---

<header class="header">
  <div class="inner">
    <a class="brand" href={homeHref}>{SITE.name}</a>
    <nav class="nav" aria-label="Main">
      <a href={localePath(lang)}>{t.home}</a>
      <a href={localePath(lang, 'about')}>{t.about}</a>
      <a href={localePath(lang, 'how-we-test')}>{t.testing}</a>
      <a href={localePath(lang, 'contact')}>{t.contact}</a>
      <a href={localePath(lang, 'privacy')}>{t.privacy}</a>
    </nav>
    <div class="lang-switch" aria-label="Language">
      {LOCALES.map((l) => (
        <a
          href={localePath(l, subPath)}
          class:list={['lang', { active: l === lang }]}
          hreflang={l}
        >
          {LOCALES.indexOf(l) < 3 ? l.toUpperCase() : LOCALE_LABELS[l].slice(0, 2)}
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  .header {
    background: rgba(15, 23, 42, 0.96);
    backdrop-filter: blur(16px);
    color: #f8fafc;
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .inner {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.25rem;
  }
  .brand {
    font-weight: 800;
    font-size: 1.08rem;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .brand::before {
    content: '';
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #38bdf8, #22c55e);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
  }
  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    flex: 1;
  }
  .nav a {
    color: #cbd5e1;
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 600;
    padding: 0.2rem 0;
  }
  .nav a:hover {
    color: #fff;
  }
  .lang-switch {
    display: flex;
    gap: 0.35rem;
    padding: 0.22rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.55);
  }
  .lang {
    font-size: 0.72rem;
    padding: 0.2rem 0.48rem;
    border-radius: 999px;
    color: #94a3b8;
    text-decoration: none;
    border: 1px solid transparent;
  }
  .lang.active,
  .lang:hover {
    color: #fff;
    border-color: rgba(96, 165, 250, 0.3);
    background: rgba(37, 99, 235, 0.65);
  }
  @media (max-width: 720px) {
    .inner {
      gap: 0.7rem;
    }
    .brand {
      width: 100%;
    }
    .nav {
      order: 3;
      width: 100%;
      gap: 0.55rem 0.85rem;
    }
    .lang-switch {
      margin-left: auto;
      overflow-x: auto;
      max-width: 100%;
    }
  }
</style>
