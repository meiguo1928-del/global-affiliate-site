---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { LOCALES, type Locale } from '../../../config';
import { ui } from '../../../i18n/ui';
import { localePath } from '../../../utils/locale';

const categoryDefs = {
  'ai-tools': {
    title: {
      en: 'AI Tools Buying Guides',
      de: 'Kaufberater für KI-Tools',
      ja: 'AIツール購入ガイド',
      fr: 'Guides d’achat d’outils IA',
      es: 'Guías de compra de herramientas de IA',
      pt: 'Guias de compra de ferramentas de IA',
      th: 'คู่มือซื้อเครื่องมือ AI',
      vn: 'Hướng dẫn mua công cụ AI',
    },
    desc: {
      en: 'Compare pricing, alternatives, and use-cases for AI and automation software.',
      de: 'Preis, Alternativen und Einsatzfälle von KI- und Automatisierungstools vergleichen.',
      ja: 'AI・自動化ツールの価格、代替案、用途を比較します。',
      fr: 'Comparer prix, alternatives et usages des logiciels IA et d’automatisation.',
      es: 'Compara precios, alternativas y casos de uso de herramientas de IA y automatización.',
      pt: 'Compare preços, alternativas e usos de ferramentas de IA e automação.',
      th: 'เปรียบเทียบราคา ทางเลือก และการใช้งานของเครื่องมือ AI และระบบอัตโนมัติ',
      vn: 'So sánh giá, lựa chọn thay thế và cách dùng công cụ AI/tự động hóa.',
    },
    test: /ai|automation|content|seo|saas/i,
  },
  hosting: {
    title: {
      en: 'Hosting Buying Guides',
      de: 'Hosting-Kaufberater',
      ja: 'ホスティング購入ガイド',
      fr: 'Guides d’achat d’hébergement',
      es: 'Guías de compra de hosting',
      pt: 'Guias de compra de hospedagem',
      th: 'คู่มือซื้อโฮสติ้ง',
      vn: 'Hướng dẫn mua hosting',
    },
    desc: {
      en: 'Find the best-value hosting and website tools for beginners and small businesses.',
      de: 'Die besten Hosting- und Website-Tools für Einsteiger und kleine Unternehmen finden.',
      ja: '初心者と小規模事業向けにコスパの良いホスティングを選べます。',
      fr: 'Trouver un hébergement fiable et rentable pour débutants et petites entreprises.',
      es: 'Encuentra el hosting y herramientas web con mejor relación calidad-precio.',
      pt: 'Encontre hospedagem de bom custo-benefício para iniciantes e pequenos negócios.',
      th: 'เลือกโฮสติ้งและเครื่องมือเว็บไซต์ที่คุ้มค่าสำหรับผู้เริ่มต้นและธุรกิจเล็ก',
      vn: 'Chọn hosting đáng tiền cho người mới, blog và website bán hàng nhỏ.',
    },
    test: /hosting|wordpress|domain|server|website/i,
  },
  security: {
    title: {
      en: 'Security Buying Guides',
      de: 'Sicherheits-Kaufberater',
      ja: 'セキュリティ購入ガイド',
      fr: 'Guides d’achat sécurité',
      es: 'Guías de compra de seguridad',
      pt: 'Guias de compra de segurança',
      th: 'คู่มือซื้อเครื่องมือความปลอดภัย',
      vn: 'Hướng dẫn mua công cụ bảo mật',
    },
    desc: {
      en: 'Compare VPN and privacy tools before paying for a yearly plan.',
      de: 'VPN- und Datenschutz-Tools vor dem Kauf eines Jahresplans vergleichen.',
      ja: '年間プランを契約する前にVPNとプライバシーツールを比較できます。',
      fr: 'Comparer VPN et outils de confidentialité avant de payer un abonnement annuel.',
      es: 'Compara VPN y herramientas de privacidad antes de pagar un plan anual.',
      pt: 'Compare VPNs e ferramentas de privacidade antes de pagar um plano anual.',
      th: 'เปรียบเทียบ VPN และเครื่องมือความเป็นส่วนตัวก่อนจ่ายรายปี',
      vn: 'So sánh VPN và công cụ bảo mật trước khi trả phí gói năm.',
    },
    test: /vpn|security|privacy|password/i,
  },
} as const;

type CategorySlug = keyof typeof categoryDefs;

export async function getStaticPaths() {
  return LOCALES.flatMap((lang) =>
    ['ai-tools', 'hosting', 'security'].map((slug) => ({ params: { lang, slug } })),
  );
}

const { lang, slug } = Astro.params as { lang: Locale; slug: CategorySlug };
const category = categoryDefs[slug];
const t = ui[lang].home;

const allArticles = (await getCollection('articles'))
  .filter((a) => a.data.lang === lang)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const articles = allArticles.filter((a) => category.test.test((a.data.keywords ?? []).join(' ')));
---

<BaseLayout
  title={category.title[lang]}
  description={category.desc[lang]}
  lang={lang}
  subPath={`category/${slug}`}
>
  <h1>{category.title[lang]}</h1>
  <p class="hero-sub">{category.desc[lang]}</p>

  {
    articles.length > 0 ? (
      <div class="card-grid">
        {articles.map((article) => (
          <a class="card" href={localePath(lang, article.data.permalink)}>
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <p>{t.emptyTrack}</p>
    )
  }
</BaseLayout>
