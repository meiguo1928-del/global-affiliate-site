---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import type { Locale } from '../config';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  subPath?: string;
  alternates?: Partial<Record<Locale, string>>;
  keywords?: string[];
  isHome?: boolean;
  isRoot?: boolean;
}

const { title, description, lang, subPath = '', alternates, keywords, isHome = false, isRoot = false } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEO
      title={title}
      description={description}
      lang={lang}
      path={subPath}
      alternates={alternates}
      keywords={keywords}
      isHome={isHome}
      isRoot={isRoot}
    />
    <GoogleAnalytics />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header lang={lang} subPath={subPath} />
    <main class="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    font-family: Inter, system-ui, sans-serif;
    background:
      radial-gradient(circle at top left, rgba(59, 130, 246, 0.1), transparent 32rem),
      linear-gradient(180deg, #f8fafc 0%, #eef4fb 100%);
    color: #0f172a;
    line-height: 1.65;
  }
  .main {
    max-width: 1040px;
    margin: 0 auto;
    padding: 2.4rem 1.25rem 1rem;
  }
  h1 {
    font-size: clamp(1.65rem, 4vw, 2.15rem);
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }
  h2 {
    font-size: 1.35rem;
    margin: 2rem 0 0.75rem;
    letter-spacing: -0.02em;
  }
  h3 {
    font-size: 1.1rem;
    margin: 1.5rem 0 0.5rem;
  }
  p,
  li {
    color: #334155;
  }
  a {
    color: #2563eb;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.92rem;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
  }
  th,
  td {
    padding: 0.65rem 0.85rem;
    text-align: left;
    border-bottom: 1px solid #e2e8f0;
  }
  th {
    background: #f8fafc;
    font-weight: 600;
  }
  .cta-box {
    background: linear-gradient(135deg, #0f172a, #1e3a8a);
    color: #fff;
    border-radius: 18px;
    padding: 1.45rem 1.6rem;
    margin: 2.25rem 0;
    text-align: center;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.16);
  }
  .cta-box p {
    color: #dbeafe;
    margin: 0 0 1rem;
  }
  .cta-btn {
    display: inline-block;
    background: #fff;
    color: #1d4ed8;
    font-weight: 700;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    margin: 0.25rem;
  }
  .cta-btn:hover {
    background: #eff6ff;
  }
  .meta {
    color: #64748b;
    font-size: 0.88rem;
    margin-bottom: 1.5rem;
  }
  .card-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    margin-top: 1.5rem;
  }
  .card {
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 18px;
    padding: 1.25rem;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.11);
  }
  .card h3 {
    margin: 0 0 0.5rem;
    color: #0f172a;
  }
  .card p {
    margin: 0;
    font-size: 0.9rem;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: #475569;
    max-width: 42em;
  }
  .hero-panel {
    position: relative;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 28px;
    padding: clamp(1.35rem, 4vw, 2.4rem);
    box-shadow: 0 22px 60px rgba(15, 23, 42, 0.08);
  }
  .hero-panel::after {
    content: '';
    position: absolute;
    inset: auto -5rem -7rem auto;
    width: 15rem;
    height: 15rem;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.1);
    pointer-events: none;
  }
  .eyebrow {
    color: #2563eb;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.76rem;
    margin: 0 0 0.55rem;
  }
  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 1.15rem 0 1.25rem;
  }
  .trust-row span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #0f766e;
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: 999px;
    padding: 0.35rem 0.65rem;
    font-weight: 700;
    font-size: 0.8rem;
  }
  .trust-row span::before {
    content: '✓';
    font-weight: 900;
  }
  .quick-note {
    margin: 1rem 0 1.6rem;
    padding: 0.9rem 1.1rem;
    background: rgba(248, 250, 252, 0.8);
    border: 1px solid #dbe3ef;
    border-radius: 16px;
  }
  .quick-note strong {
    display: block;
    margin-bottom: 0.45rem;
  }
  .quick-note ul {
    margin: 0.2rem 0 0 1.1rem;
  }
  .track-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    margin: 0.9rem 0 1.5rem;
  }
  .track-card {
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 18px;
    padding: 1.1rem 1.1rem 1rem;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .track-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    color: #0f172a;
  }
  .track-card p {
    margin: 0;
    font-size: 0.9rem;
    color: #475569;
  }
  .track-card:hover {
    transform: translateY(-2px);
    border-color: #93c5fd;
    box-shadow: 0 16px 38px rgba(37, 99, 235, 0.1);
  }
  .track-kicker,
  .article-lang {
    display: inline-block;
    margin-bottom: 0.65rem;
    color: #1d4ed8;
    background: #eff6ff;
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 800;
  }
  .card-action {
    display: inline-block;
    margin-top: 0.9rem;
    color: #2563eb;
    font-size: 0.86rem;
    font-weight: 800;
  }
  .deals-box {
    margin: 1.35rem 0 1.8rem;
    padding: 1.25rem;
    background: linear-gradient(135deg, #10243f, #1e3a8a);
    border-radius: 22px;
    color: #e2e8f0;
    box-shadow: 0 20px 55px rgba(30, 58, 138, 0.18);
  }
  .deals-box h2 {
    margin: 0 0 0.3rem;
    color: #fff;
  }
  .deals-box p {
    margin: 0 0 0.9rem;
    color: #cbd5e1;
    font-size: 0.92rem;
  }
  .deals-grid {
    display: grid;
    gap: 0.7rem;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  }
  .deal-item {
    background: rgba(255, 255, 255, 0.95);
    border-radius: 16px;
    padding: 0.8rem 0.9rem;
    text-decoration: none;
    color: #0f172a;
    border: 1px solid rgba(191, 219, 254, 0.82);
    transition: transform 0.15s, border-color 0.15s;
  }
  a.deal-item:hover {
    transform: translateY(-2px);
    border-color: #60a5fa;
  }
  .deal-item strong {
    display: block;
    margin-top: 0.2rem;
    color: #1d4ed8;
  }
  .deal-disabled {
    opacity: 0.72;
    cursor: not-allowed;
    background: rgba(248, 250, 252, 0.78);
  }
  .deal-badge {
    display: inline-block;
    font-size: 0.72rem;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: #eff6ff;
    color: #1e3a8a;
  }
  .section-block {
    margin-top: 1.9rem;
  }
  .category-hero {
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 24px;
    padding: clamp(1.25rem, 4vw, 2rem);
    margin-bottom: 1.4rem;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.07);
  }
  .category-hero span {
    display: inline-block;
    margin-bottom: 0.55rem;
    color: #0f766e;
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    font-size: 0.78rem;
    font-weight: 800;
  }
  article {
    max-width: 820px;
    margin: 0 auto;
  }
  article > h1 {
    font-size: clamp(1.85rem, 4vw, 2.55rem);
  }
  article p,
  article li {
    font-size: 1rem;
  }
  article h2 {
    padding-top: 0.35rem;
  }
  .article-hero {
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 24px;
    padding: clamp(1.1rem, 3vw, 1.8rem);
    margin-bottom: 1.35rem;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.07);
  }
  .article-hero .disclosure {
    margin-bottom: 1.2rem;
  }
  @media (max-width: 720px) {
    .main {
      padding-top: 1.35rem;
    }
    .hero-panel {
      border-radius: 20px;
    }
    table {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>
