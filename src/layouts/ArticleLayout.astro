---
import BaseLayout from './BaseLayout.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import { AFFILIATE_LINKS, isRealAffiliateLink, type Locale } from '../config';
import { ui } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  slug: string;
  date: Date;
  updated?: Date;
  alternates?: Partial<Record<Locale, string>>;
  keywords?: string[];
}

const { title, description, lang, slug, date, updated, alternates, keywords } = Astro.props;
const t = ui[lang].article;
const joinedKeywords = (keywords ?? []).join(' ').toLowerCase();
const ctaLinks = joinedKeywords.includes('hosting')
  ? [{ href: AFFILIATE_LINKS.hostinger, label: t.ctaHostinger }]
  : [
      { href: AFFILIATE_LINKS.surfshark, label: t.ctaSurfshark },
      { href: AFFILIATE_LINKS.nordvpn, label: t.ctaNordvpn },
    ];
const fmt = (d: Date) =>
  d.toLocaleDateString(lang === 'en' ? 'en-US' : lang, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  subPath={slug}
  alternates={alternates}
  keywords={keywords}
>
  <article>
    <header class="article-hero">
      <AffiliateDisclosure lang={lang} />
      <h1>{title}</h1>
      <p class="meta">
        {t.updated}: {fmt(updated ?? date)}
      </p>
    </header>
    <slot />
    <div class="cta-box">
      <p>{t.ctaIntro}</p>
      {
        ctaLinks.some((link) => isRealAffiliateLink(link.href)) ? (
          ctaLinks.map((link) =>
            isRealAffiliateLink(link.href) ? (
              <a class="cta-btn" href={link.href} rel="nofollow sponsored" target="_blank">
                {link.label}
              </a>
            ) : null,
          )
        ) : (
          <p class="cta-pending">{t.ctaPending}</p>
        )
      }
    </div>
  </article>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  inLanguage: lang,
  author: { '@type': 'Organization', name: 'Tool Scout Lab' },
})} />
